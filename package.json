{
  "name": "kingston-care-connect",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env FORCE_COLOR=1 next dev --turbo",
    "build": "next build",
    "postbuild": "node --import tsx scripts/generate-embeddings.ts",
    "start": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci:check": "bash scripts/validate-ci.sh",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test --project=chromium",
    "db:validate": "node --import tsx scripts/validate-data.ts",
    "db:verify": "node --import tsx scripts/verify-db-integrity.ts",
    "tools:search": "node --import tsx scripts/search-cli.ts",
    "prepare": "husky",
    "bilingual-check": "node --import tsx scripts/bilingual-audit.ts",
    "audit:qa": "node --import tsx scripts/qa-audit.ts",
    "audit:coords": "node --import tsx scripts/export-coordinate-gaps.ts --out docs/audits/v17-5/coordinates/outputs/coordinate-gaps.json",
    "audit:hours": "node --import tsx scripts/export-hours-gaps.ts --out docs/audits/v17-5/hours/outputs/hours-gaps.json",
    "audit:access-scripts": "node --import tsx scripts/audit-access-scripts.ts --out docs/audits/v17-5/ai-results/reports/access-script-audit.json",
    "backfill:hours-text": "node --import tsx scripts/backfill-hours-text.ts",
    "audit:l3": "node --import tsx scripts/export-l3-candidate-suggestions.ts",
    "export:access-script-fr": "node --import tsx scripts/export-access-script-fr-translation-batches.ts --out-dir docs/audits/v17-5/ai-results/access-script-fr/input",
    "translate:prompt": "node --import tsx scripts/batch-translate-helper.ts generate-prompt",
    "translate:parse": "node --import tsx scripts/batch-translate-helper.ts parse-response",
    "translate:validate": "node --import tsx scripts/batch-translate-helper.ts validate",
    "audit:bilingual": "node --import tsx scripts/bilingual-audit.ts",
    "i18n-audit": "node --import tsx scripts/i18n-key-audit.ts",
    "health-check": "node --import tsx scripts/health-check-urls.ts",
    "phone-validate": "node --import tsx scripts/validate-phones.ts",
    "geocode": "node --import tsx scripts/geocode-services.ts",
    "validate-data": "node --import tsx scripts/validate-services.ts",
    "check-staleness": "node --import tsx scripts/check-staleness.ts",
    "audit:data": "node --import tsx scripts/audit-data-completeness.ts",
    "mobile:sync": "npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:build": "next build && npx cap sync",
    "premobile:sync": "node --import tsx scripts/check-mobile-environment.ts",
    "premobile:build": "node --import tsx scripts/check-mobile-environment.ts",
    "check:root": "bash scripts/check-root-hygiene.sh",
    "test:a11y": "npx playwright test tests/e2e/accessibility-audit.spec.ts tests/e2e/accessibility-interactive.spec.ts",
    "test:load": "[ -f ./bin/k6 ] && ./bin/k6 run tests/load/search-api.k6.js || k6 run tests/load/search-api.k6.js",
    "test:load:smoke": "[ -f ./bin/k6 ] && ./bin/k6 run tests/load/smoke-test.k6.js || k6 run tests/load/smoke-test.k6.js",
    "test:load:sustained": "[ -f ./bin/k6 ] && ./bin/k6 run tests/load/sustained-load.k6.js || k6 run tests/load/sustained-load.k6.js",
    "test:load:spike": "[ -f ./bin/k6 ] && ./bin/k6 run tests/load/spike-test.k6.js || k6 run tests/load/spike-test.k6.js",
    "analyze:load-test": "node --import tsx scripts/analyze-load-test-results.ts",
    "validate:env": "node --import tsx scripts/validate-env-config.ts",
    "qa:prelaunch": "node --import tsx scripts/run-prelaunch-qa.ts",
    "release:notes": "node scripts/generate-release-notes.js",
    "vercel:verify": "bash scripts/verify-vercel-optimization.sh",
    "vercel:optimize": "bash scripts/apply-vercel-optimization.sh"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "tar": "^7.5.7"
  },
  "dependencies": {
    "@axiomhq/js": "1.4.0",
    "@capacitor/android": "^8.0.1",
    "@capacitor/app": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/network": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@mlc-ai/web-llm": "^0.2.80",
    "@next/bundle-analyzer": "^15.3.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-form": "^0.0.3",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.13",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "^1.3.6",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "^1.3.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle-group": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "2.90.1",
    "@swc/helpers": "0.5.18",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "idb": "^8.0.3",
    "lodash": "^4.17.21",
    "lucide-react": "0.562.0",
    "next": "^15.5.9",
    "next-intl": "4.7.0",
    "next-themes": "^0.4.6",
    "openai": "^4.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "7.71.1",
    "react-markdown": "^10.1.0",
    "react-onesignal": "^3.4.6",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@google/generative-ai": "^0.24.1",
    "@next/eslint-plugin-next": "15.1.6",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.3.1",
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.17.43",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.26.0",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "husky": "^9.1.7",
    "inquirer": "^13.1.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.1",
    "prettier": "3.8.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "supabase": "^2.72.7",
    "tailwindcss": "^4.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "undici": "7.18.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "web-push": "^3.6.7"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.0.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "next lint --fix --file",
      "vitest related --run"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
