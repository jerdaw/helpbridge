# .env.example

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# AI/ML Features (Optional)
OPENAI_API_KEY=your-openai-api-key

# Data Enrichment (for geocoding addresses)
OPENCAGE_API_KEY=your-opencage-api-key

# Twilio (for phone validation scripts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION="1.0.0-pilot"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-vapid-key
VAPID_PRIVATE_KEY=your-private-vapid-key

# Search Configuration
NEXT_PUBLIC_SEARCH_MODE=local # "local" or "server"

# Mobile / Push Notifications (v15.0)
NEXT_PUBLIC_MOBILE_INFRASTRUCTURE=true
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-rest-api-key # Server-side only

# Performance Tracking (v17.5+)
# Enable performance tracking and metrics collection (development/staging only)
NEXT_PUBLIC_ENABLE_SEARCH_PERF_TRACKING=false

# Circuit Breaker Configuration (v17.5+)
# Enable circuit breaker pattern for Supabase resilience
CIRCUIT_BREAKER_ENABLED=true
# Number of consecutive failures before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# Time in ms to wait before attempting recovery (OPEN -> HALF_OPEN)
CIRCUIT_BREAKER_TIMEOUT=30000

# Axiom Observability (v18.0 Phase 2)
# Sign up at https://axiom.co (free tier: 500GB/month)
# Create dataset and generate API token in Settings
AXIOM_TOKEN=xait-your-api-token-here
AXIOM_ORG_ID=your-organization-id
AXIOM_DATASET=kingston-care-production

# Slack Integration (v18.0 Phase 2)
# Create incoming webhook at https://slack.com/apps/A0F7XDUAZ-incoming-webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# Cron Job Authentication (v18.0 Phase 2)
# Generate a secure random string: openssl rand -base64 32
CRON_SECRET=your-random-secret-string
